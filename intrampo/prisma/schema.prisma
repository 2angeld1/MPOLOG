generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Comunicado {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  titulo      String
  contenido   String
  categoria   String   @default("general") // "pastoral", "admin", "lideres", "servidores", "general"
  imagenUrl   String?
  archivoUrl  String?
  autorId     String   // MongoDB ObjectId del usuario
  autorNombre String
  fijado      Boolean  @default(false)
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Ministerio {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  nombre      String   @unique
  descripcion String?
  liderIds    String[] // MongoDB ObjectIds
  color       String   @default("#673AB7")
  icono       String   @default("church")
  miembrosIds String[] // MongoDB ObjectIds
  activo        Boolean  @default(true)
  parentId      String?  @db.ObjectId
  padre         Ministerio?  @relation("Subdivisiones", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subdivisiones Ministerio[] @relation("Subdivisiones")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Solicitud {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  tipo              String   // "salon", "equipo", "consejeria", "otro"
  titulo            String
  descripcion       String
  solicitanteId     String   // MongoDB ObjectId
  solicitanteNombre String
  estado            String   @default("pendiente") // "pendiente", "aprobada", "rechazada"
  respuesta         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ContenidoDinamico {
  llave       String   @id @map("_id")
  tipo        String   // "texto", "imagen", "html"
  valor       String
  actualizado DateTime @updatedAt
}

model RolUsuario {
  userId    String   @id @map("_id") // MongoDB ObjectId
  rol       String   // "pastor", "lideres", "servidores", "general"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Archivo {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  nombre          String
  url             String
  public_id       String
  formato         String
  tamano          Int
  subidoPorId     String   // MongoDB ObjectId
  subidoPorNombre String? // Opcional, cachear nombre para no hacer join a Mongo
  carpeta         String   @default("/")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SolicitudRecurso {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  liderId               String   // MongoDB ObjectId
  liderNombre           String?
  descripcionEquipo     String
  fotoEstadoActual      String?
  fechaSalida           DateTime
  fechaEstimadaRegreso  DateTime
  estado                String   @default("Solicitado") // "Solicitado", "Retirado", "Disponible"
  observacionesRetorno  String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model MiembroDirectorio {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  nombre          String
  edad            Int
  telefono        String
  tiempoIglesia   String   // ej. "Menos de 1 año", "1-3 años", "Más de 5 años"
  esServidor      Boolean  @default(false)
  dondeSirve      String?
  parentesco      String?
  fotoUrl         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UsuarioSistema {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  nombre              String
  email               String   @unique
  password            String
  rol                 String
  miembroDirectorioId String?  @db.ObjectId
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
